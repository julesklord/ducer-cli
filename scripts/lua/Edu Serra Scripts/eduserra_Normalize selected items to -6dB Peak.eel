// Normalize Selected Items to -6dB Peak
// Written in EEL by ChatGPT

//desc:Normalize Selected Items to -6dB Peak

slider1:Peak;0;-20;0;0.1

in_pin:none
out_pin:none

reaper.gmem_attach('chatgpt')

function main()

    -- Loop through selected items
    local sel_items = reaper.CountSelectedMediaItems(0)
    for i = 0, sel_items-1 do
        local item = reaper.GetSelectedMediaItem(0, i)
        
        -- Loop through takes in each selected item
        local takes = reaper.CountTakes(item)
        for t = 0, takes-1 do
            local take = reaper.GetMediaItemTake(item, t)
            
            -- Get peak volume
            local peak_vol = reaper.GetMediaItemTakeInfo_Value(take, "D_VOL")
            
            -- Calculate gain adjustment needed
            local gain_adjustment = -20 * (math.log10(peak_vol) - math.log10(0.50118723362727)) - 6
            local new_vol = peak_vol * (10 ^ (gain_adjustment / 20))
            
            -- Apply gain adjustment to take
            reaper.SetMediaItemTakeInfo_Value(take, "D_VOL", new_vol)
            
            reaper.UpdateItemInProject(item)
        end
    end
    
    reaper.UpdateArrange()
    
end

function on_slider1_change()
    reaper.gmem_write('chatgpt', 'peak', Peak)
end

function on_midi_event()
end

function on_sysex_event()
end

